---
import Layout from "../layouts/Layout.astro";

// Listado oficial de las 5 integrantes con sus nombres y perfiles de LinkedIn reales
const equipo = [
  { 
    inicial: "E", 
    nombre: "Elena Pavón", 
    linkedin: "https://www.linkedin.com/in/elenapavonfernandez/", 
    img: "/CoreNexusFive/equipo-e.jpg" 
  },
  { 
    inicial: "C", 
    nombre: "Claudia Cervantes", 
    linkedin: "https://www.linkedin.com/in/claudia-cervantes-worldwide/?locale=es", 
    img: "/CoreNexusFive/equipo-c.jpg" 
  },
  { 
    inicial: "N", 
    nombre: "Nieves Pérez", 
    linkedin: "https://www.linkedin.com/in/nievesperezalonso", 
    img: "/CoreNexusFive/mi-logo-propio.png" 
  },
  { 
    inicial: "E", 
    nombre: "Esther Quirós", 
    linkedin: "https://www.linkedin.com/in/esther-quir%C3%B3s/", 
    img: "/CoreNexusFive/equipo-e2.jpg" 
  },
  { 
    inicial: "M", 
    nombre: "Mayka Durán", 
    linkedin: "https://www.linkedin.com/in/mdelcarmenduran/", 
    img: "/CoreNexusFive/equipo-m.jpg" 
  }
];
---

<Layout
  title="Project Overview | Core Nexus Five"
  description="La génesis, concepto y el equipo detrás de la solución integral de arquitectura de datos en AWS."
  pubDate={new Date("May 16 2026")}
  heroImage="/blog-placeholder-about.jpg"
>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&display=swap" rel="stylesheet">

  <section class="flex grow py-10 flex-col pb-40 justify-center items-center px-4">
    
    <!-- Hero Statement (Texto grande modificado) -->
    <h1 class="text-4xl md:text-5xl font-fugaz font-bold pt-20 pb-16 text-center max-w-4xl w-full uppercase leading-tight">
      "Donde la formación se convierte en arquitectura. Core Nexus Five es la convergencia de cinco mentes y todo un ecosistema AWS para dominar el ciclo de vida del dato."
    </h1>

    <!-- Contenedor General de la Página -->
    <div class="w-full flex flex-col items-center space-y-16">
      
      <!-- Bloque 1: Origen del Proyecto -->
      <div class="text-block-container block-clean-relative">
        <h2 class="text-xl md:text-2xl font-fugaz font-bold mb-4 uppercase">
          La Génesis de Core Nexus Five
        </h2>
        <p class="text-lg leading-relaxed text-gray-700 dark:text-gray-300">
          Core Nexus Five no es solo una arquitectura técnica; es el proyecto final de mi formación en <strong>AWS Re/Start</strong>. Representa el punto de inflexión donde todos los conceptos aprendidos durante meses —redes, seguridad, almacenamiento y computación— convergieron por fin para dar sentido al mundo de los datos.
        </p>

        <!-- Nota manuscrita 1 -->
        <div class="side-note">
          <svg class="marker-arrow" viewBox="0 0 120 80">
            <path d="M-20,40 Q30,35 110,40" stroke="black" stroke-width="12" fill="none" stroke-linecap="round"/>
            <path d="M85,20 L112,41 L85,60" stroke="black" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="handwritten-text">El origen del Nexo</span>
        </div>
      </div>

      <!-- Bloque 2: Las 5 Mentes / El Equipo (Sustituye al Video Antiguo) -->
      <div class="w-full max-w-4xl space-y-8">
        <div class="text-block-container mx-auto">
          <h2 class="text-xl md:text-2xl font-fugaz font-bold mb-2 uppercase">
            El Nexo Original
          </h2>
          <p class="text-lg leading-relaxed text-gray-700 dark:text-gray-300">
            El nombre rinde tributo a la sinergia de los cinco integrantes del equipo original en la demo final. Como su nombre indica, este "Nexo" fue el reto donde logramos unificar piezas dispersas en una solución integral. Haz clic en sus iniciales para conectar en LinkedIn.
          </p>
        </div>
        
        <!-- Cuadrícula de Imágenes de las Participantes -->
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 w-full pt-4">
          {equipo.map((member) => (
            <div class="flex flex-col items-center bg-white border-2 border-black p-4 shadow-[6px_6px_0px_rgba(0,0,0,0.08)] rounded-xl group hover:-translate-y-1 transition-transform">
              <div class="w-full aspect-square overflow-hidden rounded-lg border border-neutral-200 bg-neutral-100 mb-3">
                <img 
                  src={member.img} 
                  alt={`Fotografía de ${member.nombre}`} 
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-350"
                />
              </div>
              <a 
                href={member.linkedin} 
                target="_blank" 
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-full bg-neutral-950 text-white flex items-center justify-center font-fugaz font-bold text-lg hover:bg-blue-600 transition-colors shadow-sm"
                title={`Ver perfil de LinkedIn de ${member.nombre}`}
              >
                {member.inicial}
              </a>
              <span class="text-xs text-neutral-500 font-medium mt-2 text-center truncate w-full">{member.nombre}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Bloque 3: Pilares del Ecosistema -->
      <div class="text-block-container block-clean-relative">
        <div class="block-card featured-card">
          <h2 class="text-lg md:text-xl font-fugaz font-bold mb-4 uppercase">
            Ecosistema de Datos Presentado
          </h2>
          <p class="text-base leading-relaxed text-gray-800 mb-4">
            En esta plataforma, presento mi documentación detallada y visión técnica de este ecosistema, profundizando en los tres pilares fundamentales de AWS:
          </p>
          <ul class="space-y-3 text-sm text-gray-800 font-medium">
            <li class="flex items-start gap-2">
              <span class="text-black font-bold">■ S3:</span> El núcleo (Core) de almacenamiento inagotable.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-black font-bold">■ Glue:</span> La inteligencia que cataloga y dota de estructura al caos.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-black font-bold">■ Athena:</span> La herramienta de consulta que extrae el valor analítico final.
            </li>
          </ul>

          <!-- Nota manuscrita 2 -->
          <div class="side-note">
            <svg class="marker-arrow" viewBox="0 0 120 80">
              <path d="M-20,40 Q30,35 110,40" stroke="black" stroke-width="12" fill="none" stroke-linecap="round"/>
              <path d="M85,20 L112,41 L85,60" stroke="black" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="handwritten-text">S3 + Glue + Athena</span>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  body {
    overflow-x: hidden;
    margin: 0;
    padding: 0;
  }

  /* Contenedor estático para bloques de texto */
  .text-block-container {
    max-width: 450px; 
    width: 100%;
    position: relative;
    box-sizing: border-box;
  }

  .block-clean-relative {
    position: relative;
  }

  /* Tarjeta del ecosistema */
  .block-card {
    border: 1px solid rgba(0, 0, 0, 0.1);
    padding: 35px 35px;
    position: relative; 
    background-color: #ffffff;
  }

  .featured-card {
    border: 2px solid #000000 !important; 
    box-shadow: 10px 10px 0px rgba(0, 0, 0, 0.08); 
    animation: gentle-pulse 4s infinite ease-in-out;
  }

  /* Notas manuscritas laterales */
  .side-note {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    right: -240px; 
    width: 210px; 
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    pointer-events: none;
  }

  .marker-arrow {
    width: 70px; 
    margin-left: -20px;
    overflow: visible;
  }

  .handwritten-text {
    font-family: 'Caveat', cursive;
    font-size: 34px; 
    font-weight: 700;
    color: #000000;
    line-height: 0.85;
    padding-left: 10px;
    transform: rotate(-1deg);
    display: block;
  }

  /* Responsivo para notas manuscritas en móvil */
  @media (max-width: 950px) {
    .side-note { 
      position: relative; 
      right: 0; 
      top: 0; 
      width: 100%; 
      margin-top: 20px;
      transform: none; 
      align-items: center;
    }
    .marker-arrow { 
      margin-left: 0; 
      transform: rotate(90deg); 
      width: 35px; 
    }
    .handwritten-text {
      text-align: center;
      padding-left: 0;
    }
  }

  @keyframes gentle-pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.012); 
      box-shadow: 14px 14px 0px rgba(0, 0, 0, 0.12); 
    }
  }
</style>
