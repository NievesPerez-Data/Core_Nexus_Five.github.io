---
// Valores por defecto seguros para que no falle la compilación si las colecciones vienen vacías
const { 
  blogCol1 = [], 
  blogCol2 = [], 
  collectionEntries = [] 
} = Astro.props;

const today = new Date().getFullYear();
---

<footer
  class="relative bg-muted pt-10 w-full md:pb-6 border-t flex flex-col md:flex-row gap-20 z-10 max-w-full overflow-hidden"
>
  <div class="container px-5 mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
    
    <div class="md:w-1/2 flex flex-col items-start gap-6 col-span-1">
      <p class="text-3xl font-semibold font-fugaz">
        ¿Quieres conocer más sobre el proyecto?
      </p>
      {/* Botón enlazado a tu LinkedIn para abrir conversación directa */}
      <a 
        href="https://www.linkedin.com/in/nievesperezalonso" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-block bg-neutral-950 text-white font-bold px-6 py-3 rounded-xl transition-all active:scale-95"
      >
        Hablemos
      </a>
    </div>

    <div class="md:w-1/2 flex flex-col justify-between md:pr-20 col-span-1">
      <p>
        Explorando la intersección entre la ingeniería de datos y la arquitectura cloud. 
        Este pipeline representa un flujo escalable y eficiente utilizando lo último en tecnología de AWS.
      </p>
      <div class="flex justify-between items-center mt-20 mb-6">
        {/* Enlace directo a tu nuevo portfolio */}
        <a 
          href="https://nievesperez-data.github.io/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="font-bold hover:text-blue-400 transition-colors"
        >
          Nieves Pérez &reg;
        </a>
        <p>{today}</p>
      </div>
    </div>

    <hr class="col-span-1 md:col-span-2" />

    <div class="col-span-1 md:col-span-2 justify-between grid md:grid-cols-4 px-6 items-start gap-6 md:gap-0">
      
      <div>
        <h2 class="font-bold uppercase text-sm mb-4">Menú</h2>
        <ul class="font-bold flex flex-col gap-2">
          {/* Enlaces corregidos: Home y Project Overview enlazado a la página interna */}
          <li><a href="/CoreNexusFive/">Home</a></li>
          <li><a href="/CoreNexusFive/overview/">Project Overview</a></li>
          <li><a href="/CoreNexusFive/arquitectura/">Stack & Data Flow</a></li>
          <li><a href="/CoreNexusFive/blog/">Documentación Técnica</a></li>
          <li><a href="/CoreNexusFive/about/">Demo & Entrega</a></li>
          <li><a href="/CoreNexusFive/contact/">Perfil Profesional</a></li>
        </ul>
      </div>

      <div>
        <h2 class="font-bold uppercase text-sm mb-4">Documentación</h2>
        <ul>
          {
            blogCol1.map((entry: any) => (
              <li class="font-bold mb-2">
                <a href={`/CoreNexusFive/blog/${entry.id}/`} class="hover:text-primary transition-colors">
                  {entry.data?.title ?? entry.id}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="font-bold uppercase text-sm mb-4 text-transparent select-none">...</h2>
        <ul>
          {
            blogCol2.map((entry: any) => (
              <li class="font-bold mb-2">
                <a href={`/CoreNexusFive/blog/${entry.id}/`} class="hover:text-primary transition-colors">
                  {entry.data?.title ?? entry.id}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="font-bold uppercase text-sm mb-4">Resultados</h2>
        <ul>
          {
            collectionEntries.map((entry: any) => (
              <li class="font-bold mb-2">
                <a href={`/CoreNexusFive/collection/${entry.id}/`} class="hover:text-primary transition-colors">
                  {entry.data?.title ?? entry.id}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

    </div>

    <hr class="col-span-1 md:col-span-2" />
    
    {/* Frase de Jeff Bezos forzada en 3 líneas balanceadas */}
    <p class="col-span-1 md:col-span-2 text-center italic text-gray-400 px-6 max-w-xl mx-auto leading-relaxed">
      "If you decide that you’re going to do only the things<br class="hidden md:inline" /> 
      you know are going to work, you’re going to leave<br class="hidden md:inline" /> 
      a lot of opportunity on the table." <span class="text-gray-400 font-semibold not-italic block mt-2">— Jeff Bezos</span>
    </p>

    {/* Icono de la Nube en color Negro y sin animación para una estética más sólida */}
    <div class="col-span-1 md:col-span-2 text-center mx-auto pb-20 text-black">
      <svg
        class="w-10 h-10 mx-auto"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"/>
      </svg>
    </div>

  </div>
</footer>
